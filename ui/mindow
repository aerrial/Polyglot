class SidebarButton(QPushButton):
    def __init__(self, text):
        super().__init__(text)
        self.setCursor(Qt.PointingHandCursor)
        self.setMinimumHeight(46)
        self.setObjectName("SidebarButton")


class Panel(QFrame):
    def __init__(self, title=""):
        super().__init__()
        self.setObjectName("Panel")

        layout = QVBoxLayout(self)
        layout.setContentsMargins(16, 16, 16, 16)
        layout.setSpacing(12)

        if title:
            label = QLabel(title)
            label.setObjectName("PanelTitle")
            layout.addWidget(label)

        self.body = QVBoxLayout()
        self.body.setSpacing(10)
        layout.addLayout(self.body)


class TimelineTrack(QFrame):
    def __init__(self, name, segments=None):
        super().__init__()
        self.setObjectName("TimelineTrack")

        layout = QHBoxLayout(self)
        layout.setContentsMargins(0, 0, 0, 0)
        layout.setSpacing(10)

        label = QLabel(name)
        label.setFixedWidth(140)
        label.setObjectName("TrackLabel")

        track = QWidget()
        track_layout = QHBoxLayout(track)
        track_layout.setContentsMargins(0, 8, 0, 8)
        track_layout.setSpacing(8)

        segments = segments or []

        for text, width, style in segments:
            seg = QLabel(text)
            seg.setMinimumWidth(width)
            seg.setAlignment(Qt.AlignCenter)
            seg.setObjectName(style)
            seg.setMinimumHeight(32)
            track_layout.addWidget(seg)

        track_layout.addStretch()

        layout.addWidget(label)
        layout.addWidget(track)


class SpeakerCard(QFrame):
    def __init__(self, speaker, voice, status="Mapped"):
        super().__init__()
        self.setObjectName("SpeakerCard")

        layout = QVBoxLayout(self)
        layout.setContentsMargins(14, 14, 14, 14)

        top = QLabel(speaker)
        top.setObjectName("SpeakerName")

        voice_label = QLabel(voice)
        voice_label.setObjectName("SpeakerVoice")

        status_label = QLabel(status)
        status_label.setObjectName("SpeakerStatus")

        btn_row = QHBoxLayout()

        preview_btn = QPushButton("Preview")
        replace_btn = QPushButton("Replace")

        preview_btn.setObjectName("SecondaryButton")
        replace_btn.setObjectName("PrimaryButton")

        btn_row.addWidget(preview_btn)
        btn_row.addWidget(replace_btn)

        layout.addWidget(top)
        layout.addWidget(voice_label)
        layout.addWidget(status_label)
        layout.addSpacing(10)
        layout.addLayout(btn_row)


class PolyGlotWindow(QMainWindow):
    def __init__(self):
        super().__init__()

        self.setWindowTitle("PolyGlot AI Studio")
        self.resize(1500, 780)

        self.setup_toolbar()
        self.setup_ui()
        self.apply_styles()

    def setup_toolbar(self):
        toolbar = QToolBar()
        toolbar.setMovable(False)
        toolbar.setObjectName("TopToolbar")

        file_action = QAction("File", self)
        edit_action = QAction("Edit", self)
        workspace_action = QAction("Workspace", self)
        ai_action = QAction("AI Sync", self)

        toolbar.addAction(file_action)
        toolbar.addAction(edit_action)
        toolbar.addAction(workspace_action)
        toolbar.addAction(ai_action)

        self.addToolBar(toolbar)

    def setup_ui(self):
        root = QWidget()
