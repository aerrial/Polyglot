        sidebar.setFixedWidth(250)

        sidebar_layout = QVBoxLayout(sidebar)
        sidebar_layout.setContentsMargins(20, 20, 20, 20)
        sidebar_layout.setSpacing(14)

        logo = QLabel("PolyGlot AI\nPro Workstation")
        logo.setObjectName("Logo")

        sidebar_layout.addWidget(logo)
        sidebar_layout.addSpacing(24)

        for item in [
            "Dashboard",
            "Projects",
            "Workspace",
            "Voices",
            "AI Models",
            "Export",
            "Settings",
        ]:
            sidebar_layout.addWidget(SidebarButton(item))

        sidebar_layout.addStretch()

        new_project = QPushButton("+ New Project")
        new_project.setMinimumHeight(54)
        new_project.setObjectName("NewProjectButton")

        sidebar_layout.addWidget(new_project)

        # CENTER WORKSPACE
        center = QWidget()
        center_layout = QVBoxLayout(center)
        center_layout.setContentsMargins(18, 18, 18, 18)
        center_layout.setSpacing(16)

        # HEADER
        header = QHBoxLayout()

        title = QLabel("AI Dubbing Workspace")
        title.setObjectName("WorkspaceTitle")

        status = QLabel("AI Sync Active")
        status.setObjectName("StatusBadge")

        translating = QLabel("Translating 84%")
        translating.setObjectName("WarningBadge")

        header.addWidget(title)
        header.addStretch()
        header.addWidget(status)
        header.addWidget(translating)

        center_layout.addLayout(header)

        # MAIN SPLITTER
        splitter = QSplitter(Qt.Horizontal)

        # LEFT PANEL
        left_panel = Panel("Transcript Editor")

        transcript = QListWidget()

        entries = [
            "00:12 Speaker 1\nWelcome to the expansion panel...",
            "00:18 Speaker 2\nWe are discussing AI localization...",
            "00:24 Speaker 1\nThe system automatically syncs voices...",
            "00:31 Speaker 3\nExport queue is ready.",
        ]

        for e in entries:
            QListWidgetItem(e, transcript)

        left_panel.body.addWidget(transcript)

        # VIDEO + TIMELINE
        middle_container = QWidget()
        middle_layout = QVBoxLayout(middle_container)
        middle_layout.setContentsMargins(0, 0, 0, 0)
        middle_layout.setSpacing(16)

        video_frame = QFrame()
        video_frame.setObjectName("VideoFrame")
        video_layout = QVBoxLayout(video_frame)

        fake_video = QLabel("VIDEO PREVIEW")
        fake_video.setAlignment(Qt.AlignCenter)
        fake_video.setObjectName("VideoPreview")
        fake_video.setMinimumHeight(460)

        controls = QHBoxLayout()

        for txt in ["⏮", "⏪", "▶", "⏩", "⏭"]:
            btn = QPushButton(txt)
            btn.setObjectName("ControlButton")
            btn.setFixedSize(48, 48)
            controls.addWidget(btn)

        controls.addSpacing(20)

        slider = QSlider(Qt.Horizontal)
        controls.addWidget(slider)

        video_layout.addWidget(fake_video)
        video_layout.addLayout(controls)

        middle_layout.addWidget(video_frame)

        # TIMELINE
        timeline = Panel("Timeline")

        tracks = [
            (
                "Original Speech",
                [
                    ("Speaker A", 170, "OriginalSegment"),
                    ("Speaker B", 220, "OriginalSegment"),
                ],
            ),
            (
                "TTS Marcus",
                [
                    ("AI Segment #42", 240, "GeneratedSegment"),
                    ("AI Segment #43", 200, "GeneratedSegment"),
                ],
            ),
            (
                "TTS Sarah",
                [
                    ("Generating", 180, "ProcessingSegment"),
                ],
            ),
        ]

        for name, segs in tracks:
            timeline.body.addWidget(TimelineTrack(name, segs))

        timeline.body.addSpacing(10)

        waveform = QProgressBar()
        waveform.setRange(0, 100)
        waveform.setValue(68)
        waveform.setTextVisible(False)
        waveform.setFixedHeight(12)
        waveform.setObjectName("Waveform")

        timeline.body.addWidget(waveform)

        middle_layout.addWidget(timeline)

        # RIGHT INSPECTOR
        right_panel = Panel("Speaker Inspector")

        right_panel.setMinimumWidth(320)
        right_panel.setMaximumWidth(380)

        right_panel.body.addWidget(
            SpeakerCard(
                "Speaker 1 (Marcus)",
                "French Male Professional",
                "AI Voice Mapped",
            )
        )

        right_panel.body.addWidget(
            SpeakerCard(
                "Speaker 2 (Sarah)",
                "French Female Warm",
                "Processing TTS",
            )
        )

        metrics = Panel("AI Pipeline")

        for label_text, value in [
            ("WhisperX", 100),
            ("Diarization", 92),
            ("Translation", 84),
            ("Voice Synthesis", 61),
        ]:
            lbl = QLabel(label_text)
            bar = QProgressBar()
            bar.setValue(value)
            metrics.body.addWidget(lbl)
            metrics.body.addWidget(bar)

        right_panel.body.addWidget(metrics)

        export_btn = QPushButton("Render & Export")
        export_btn.setObjectName("ExportButton")
        export_btn.setMinimumHeight(52)

        right_panel.body.addWidget(export_btn)
        right_panel.body.addStretch()

        splitter.addWidget(left_panel)
        splitter.addWidget(middle_container)
        splitter.addWidget(right_panel)

        splitter.setStretchFactor(0, 1)
        splitter.setStretchFactor(1, 5)
        splitter.setStretchFactor(2, 1)

        center_layout.addWidget(splitter)

        main_layout.addWidget(sidebar)
        main_layout.addWidget(center)

